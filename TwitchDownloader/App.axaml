<Application
    x:Class="TwitchDownloader.App"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:TwitchDownloader"
    xmlns:materialIcon="using:Material.Icons.Avalonia"
    xmlns:suki="using:SukiUI"
    RequestedThemeVariant="Default">
    <!--  "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options.  -->

    <Application.DataTemplates>
        <local:ViewLocator />
    </Application.DataTemplates>

    <Application.Styles>
        <suki:SukiTheme ThemeColor="Blue" />
        <materialIcon:MaterialIconStyles />
        <StyleInclude Source="Styles/Index.axaml" />
    </Application.Styles>
</Application>