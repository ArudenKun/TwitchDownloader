<UserControl
    x:Class="TwitchDownloader.Views.Pages.SettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:TwitchDownloader.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vmp="using:TwitchDownloader.ViewModels.Pages"
    d:DesignHeight="450"
    d:DesignWidth="800"
    x:DataType="vmp:SettingsViewModel"
    mc:Ignorable="d">
    <Panel HorizontalAlignment="Center" VerticalAlignment="Center">
        <controls:Hyperlink
            Content="(?)"
            NavigateUri="https://github.com/ArudenKun/TwitchDownloader"
            ToolTip.Tip="Test" />
    </Panel>
</UserControl>